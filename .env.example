# Zendesk credentials
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=agent@example.com
ZENDESK_API_TOKEN=your-api-token-here

# Webhook verification (optional but recommended)
WEBHOOK_SECRET=

# Tuning
LOOKBACK_HOURS=72
SIMILARITY_THRESHOLD=0.6
MIN_DESCRIPTION_LENGTH=20
LOG_LEVEL=INFO

# Custom merge comment (use {source_id} as placeholder)
MERGE_COMMENT=Auto-merged duplicate ticket #{source_id} from the same requester.
